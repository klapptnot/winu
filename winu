#!/usr/bin/bash

shopt -s extglob

readonly KITSH_YAML_SH='https://raw.githubusercontent.com/klapptnot/kitsh/main/lib/yaml.sh'
readonly WINU_TMP_IMAGE="${WINU_THEME_ROOT}/tmp.png"
readonly WINU_TMP_COMP_EXEC="${WINU_THEME_ROOT}/winu-sddm-compositor"
readonly WINU_SDDM_COMP_EXEC="/usr/bin/winu-sddm-compositor"
readonly WINU_MATUGEN_TEMPLATE='
WINU_COLOR_PALLETE[missing]=0
WINU_COLOR_PALLETE[background]="{{colors.background.default.hex}}"
WINU_COLOR_PALLETE[onBackground]="{{colors.on_background.default.hex}}"
WINU_COLOR_PALLETE[primary]="{{colors.primary.default.hex}}"
WINU_COLOR_PALLETE[onPrimary]="{{colors.on_primary.default.hex}}"
WINU_COLOR_PALLETE[primaryContainer]="{{colors.primary_container.default.hex}}"
WINU_COLOR_PALLETE[surface]="{{colors.surface.default.hex}}"
WINU_COLOR_PALLETE[onSurface]="{{colors.on_surface.default.hex}}"
WINU_COLOR_PALLETE[surfaceVariant]="{{colors.surface_variant.default.hex}}"
WINU_COLOR_PALLETE[onSurfaceVariant]="{{colors.on_surface_variant.default.hex}}"
WINU_COLOR_PALLETE[outline]="{{colors.outline.default.hex}}"
'
declare -g WINU_COMPOSITOR_HEAD='#!/usr/bin/bash

read -r pcount < <(pgrep --full --count "bash -s ${0}") || pcount=0
((pcount == 0)) && tail -n +8 "${0}" | setsid --fork bash -s "${0}" "${@}"
{compositor_array}
exec "${compositor[@]}" -- "${@}"

# Autogenerated: DO NOT EDIT.
readonly STOP_COMPOSITOR_TIMEOUT={compositor_timeout}'
declare -g WINU_CONFIG_TEMPLATE='import QtQuick 2.15

QtObject {
  readonly property var backgrounds: [
{bg_list}
  ]

  readonly property bool use_blur: {use_blur}
  readonly property bool use_video: {use_video}
  readonly property bool image_carousel: {carousel_enabled}
  readonly property real carousel_interval: {carousel_interval}
  readonly property real inactivityTimeout: {inactive_timeout}
  readonly property real blur_radius: {blur_radius}
  readonly property real blur_samples: {blur_samples}

  readonly property var font: {
    "primary": "{font:primary}",
    "segoe_ui": "{font:segoe_ui}",
    "meiryo_boot": "{font:meiryo_boot}"
  }

  readonly property var color: {
    "background": "{color:background}",
    "on_background": "{color:onBackground}",
    "primary": "{color:primary}",
    "on_primary": "{color:onPrimary}",
    "primary_container": "{color:primaryContainer}",
    "surface": "{color:surface}",
    "on_surface": "{color:onSurface}",
    "outline": "{color:outline}"
  }
}
'
declare -grA MATUGEN_DEFAULT_OPTS=(
  ['mode']="dark"
  ['prefer']="saturation"
)
declare -Ag WINU_COLOR_PALLETE=(['missing']=1)

if [[ -t 1 ]]; then
  readonly CLR_RED='\x1b[31m'
  readonly CLR_YEL='\x1b[33m'
  readonly CLR_GRN='\x1b[32m'
  readonly CLR_RST='\x1b[0m'
else
  readonly CLR_RED='ERROR: '
  readonly CLR_YEL='WARNING: '
  readonly CLR_GRN=''
  readonly CLR_RST=''
fi

function die {
  printf "${CLR_RED}%s${CLR_RST}\n" "${1}" >&2
  exec false
}

function warn {
  printf "${CLR_YEL}%s${CLR_RST}\n" "${1}" >&2
}

function log {
  printf "${CLR_GRN}%s${CLR_RST}\n" "${1}"
}

declare -ig __not_like_inochi_sos_whatsoever=0
function inochi-sos {
  __not_like_inochi_sos_whatsoever=1
  "${@}"
}

function become-suicidal-ahh {
  [[ "${FUNCNAME[*]}" == *' yaml::'* ]] && return
  [[ "${FUNCNAME[*]}" == *' inochi-sos '* ]] && return
  if ((__not_like_inochi_sos_whatsoever)); then
    __not_like_inochi_sos_whatsoever=0
    return
  fi
  die "sowwy i ate your ram :b ... failed command in \`${FUNCNAME[2]}\` at ${BASH_SOURCE[1]}:${BASH_LINENO}"
}

function is-command {
  command -v "${1}" &> /dev/null
}

if [[ ! -f ./yaml.sh ]]; then
  ((UID == 0)) && die "Missing yaml.sh: Run as a normal user to resolve"
  [[ -t 1 && -t 2 ]] || die "Missing yaml.sh: Run interactive to resolve"

  printf '\x1b[33myaml.sh missing. Download it here? [y/N]: \x1b[0m'
  read -rt 10 response || die 'Timeout while waiting for confirmation, aborted'
  [[ -z "${response}" || -n "${response#[Yy]}" ]] && die "Aborted"

  is-command curl || die "Error: curl is required"
  curl -fsSL "${KITSH_YAML_SH}" -o "yaml.sh" || die "Error: Download yaml.sh failed"
fi

source ./yaml.sh || die 'Unable to load yaml.sh'

function to-natural {
  if [[ "${1}" == +([0-9]) ]]; then
    printf '%s\n' "${1}"
  else
    warn "Use only natural numbers. falling back to ${2}"
    printf '%s\n' "${2}"
  fi
}

function to-boolean {
  local def="${2:-false}"

  case "${1,,}" in
    true|yes|y|1)  printf 'true\n' ;;
    false|no|n|0)  printf 'false\n' ;;
    *)
      warn "Invalid boolean '${1}', falling back to ${def}"
      printf '%s\n' "${def}"
      ;;
  esac
}

function is-video {
  case "${1##*.}" in
    mp4 | webm | mkv | mov | avi) return 0 ;;
    *) return 1 ;;
  esac
}

function is-image {
  case "${1##*.}" in
    png | jpg | jpeg | webp | gif) return 0 ;;
    *) return 1 ;;
  esac
}

function get-first-frame {
  if ! is-command ffmpeg; then
    warn "FFMPEG not installed, Material You colors won't get extracted from video"
    return 1
  fi
  log "Extracting first frame from video: ${1}"
  ffmpeg -y \
    -i "${1}" \
    -frames:v 1 \
    -update 1 \
    -c:v png \
    "${WINU_TMP_IMAGE}" &> /dev/null
}

function matugen-wrapper {
  matugen "${@}" \
    --mode "${mtu_opts[mode]:-dark}" \
    --prefer "${mtu_opts[prefer]:-saturation}" \
    --config "${WINU_MATUGEN_CONFIG}" \
    <<< "${WINU_MATUGEN_TEMPLATE}" 2> /dev/null
}

function is-valid-font {
  mapfile -t sys_fonts < <(
    fc-list \
      | grep -ioE ": [^:]*${1:?search query required}[^:]*:" \
      | sed -E 's/(^: |:)//g' \
      | tr ',' '\n' \
      | sort -u
  ) || return 1

  for f in "${sys_fonts[@]}"; do
    [[ "${f}" == "${1}" ]] && return 0
  done

  # printf '%s\n' "${fonts[@]}"
  return 1
}

function fill-template {
  log "${3:-Updating config} ${1} -> ${2}"
  WINU_CONFIG_TEMPLATE="${WINU_CONFIG_TEMPLATE/\{${1}\}/"${2}"}"
}

function dispatch::compositor {
  yaml::ensure map .compositor "${1}"
  local -n ctx="${1}"
  local -n comp_item="${ctx[compositor]}"
  local command="${comp_item[command]}"

  read -r compositor_timeout < <(to-natural "${comp_item[timeout]}" 15)

  if [[ "${command:-null}" != 'null' ]]; then
    log "Setting up compositor command..."
    is-command "${command}" || die "Compositor command '${command}' is not a command"
    local compositor=("${command}")

    inochi-sos yaml::is_value "${comp_item[args]}"
    if ((${?} == 2)); then
      local -n _ca="${comp_item[args]}"
      compositor+=("${_ca[@]}")
    fi

    log "Writing updated winu-sddm-compositor..."
    readonly compositor
    WINU_COMPOSITOR_HEAD="${WINU_COMPOSITOR_HEAD/\{compositor_array\}/"${compositor[@]@A}"}"
    WINU_COMPOSITOR_HEAD="${WINU_COMPOSITOR_HEAD/\{compositor_timeout\}/"${compositor_timeout}"}"
    cat - "${WINU_THEME_ROOT}/sddm-compositor" <<< "${WINU_COMPOSITOR_HEAD}" > "${WINU_TMP_COMP_EXEC}"
  fi
}

function dispatch::avatar {
  yaml::ensure map .avatar "${1}"
  local -n ctx="${1}"
  local -n avatar="${ctx[avatar]}"
  local avatar_custom="${avatar[custom]}"

  if [[ -n "${avatar_custom}" && "${avatar_custom}" != 'null' ]]; then
    [[ -f "${avatar_custom}" ]] || die "Custom avatar target file reference not found: ${avatar_custom}"

    log "Copying configured custom avatar profile asset..."
    cp "${avatar_custom}" "${WINU_TMP_IMAGE}"

    return
  fi

  is-command magick || die "Missing command magick (imagemagick)"
  read -r fill_avatar_bg < <(to-boolean "${avatar[filled]}")
  read -r static_colors < <(to-boolean "${avatar[static]}")

  [[ "${static_colors}" == 'true' ]] || static_colors=""

  local bg_fill="${static_colors:+#c8c5d0}"
  local fill="${static_colors:+#47464f}"

  local magick_args=(-size 192x192 xc:none)
  ${fill_avatar_bg} && magick_args+=(
    -fill "${bg_fill:-${WINU_COLOR_PALLETE[onPrimary]}}" -draw "circle 96,96 96,0"
  )

  magick_args+=(
    -fill "${fill:-${WINU_COLOR_PALLETE[primary]}}" -draw "ellipse 97.027,69.110 36.945,37.288 0,360"
    -draw "path 'M 31.959,162.515 A 69.777,71.861 0 0,1 159.72,162.515 A 94.347,97.164 0 0,1 31.959,162.515 Z'"
  )

  log "Creating defaut user avatar image..."
  magick "${magick_args[@]}" "${WINU_TMP_IMAGE}"
}

function dispatch::colors {
  yaml::ensure map .colors.matugen "${1}"
  local -n ctx="${1}"
  local use_video="${2}"
  local first_img="${3}"
  local first_vid="${4}"
  local -n colors="${ctx[colors]}"
  local -n mtu="${colors[matugen]}"

  read -r mtu_enabled < <(to-boolean "${mtu[enabled]}")

  if ${mtu_enabled} && is-command matugen; then
    log "Material You palette calculation active"
    read -r mtu_on_video < <(to-boolean "${mtu[on_video]}")
    local color_source_image=""

    if ${use_video}; then
      if ${mtu_on_video} && [[ -n "${first_vid}" ]]; then
        get-first-frame "${first_vid}" && color_source_image="${WINU_TMP_IMAGE}"
      fi
    fi

    if [[ -z "${color_source_image}" ]]; then
      [[ -z "${first_img}" ]] && die "At least one background image is required for palette construction"
      color_source_image="${first_img}"
    fi

    inochi-sos yaml::is_value "${mtu[options]}"
    if ((${?} == yaml_type_num[map])); then
      local -n mtu_opts="${mtu[options]}"
    else
      local -n mtu_opts=MATUGEN_DEFAULT_OPTS
    fi

    source <(matugen-wrapper image "${color_source_image}")
    if ((WINU_COLOR_PALLETE[missing])); then
      source <(matugen-wrapper color hex "${mtu[fallback]:-#ff4fa3}")
    fi

    rm -fr "${WINU_TMP_IMAGE}"
  else
    ${mtu_enabled} && warn "Material You palette skipped (missing matugen)"
  fi

  if ((WINU_COLOR_PALLETE[missing])); then
    yaml::ensure map .colors.palette "${1}"
    local -n c="${colors[palette]}"

    WINU_COLOR_PALLETE[background]="${c[background]:-#11111b}"
    WINU_COLOR_PALLETE[onBackground]="${c[onBackground]:-#deeeff}"
    WINU_COLOR_PALLETE[primary]="${c[primary]:-#c2c1ff}"
    WINU_COLOR_PALLETE[onPrimary]="${c[onPrimary]:-#2a2a60}"
    WINU_COLOR_PALLETE[primaryContainer]="${c[primaryContainer]:-#414178}"
    WINU_COLOR_PALLETE[surface]="${c[surface]:-#131318}"
    WINU_COLOR_PALLETE[onSurface]="${c[onSurface]:-#e4e1e9}"
    WINU_COLOR_PALLETE[surfaceVariant]="${c[surfaceVariant]:-#47464f}"
    WINU_COLOR_PALLETE[onSurfaceVariant]="${c[onSurfaceVariant]:-#c8c5d0}"
    WINU_COLOR_PALLETE[outline]="${c[outline]:-#918f9a}"
  fi
  unset WINU_COLOR_PALLETE[missing]

  for col in "${!WINU_COLOR_PALLETE[@]}"; do
    fill-template "color:${col}" "${WINU_COLOR_PALLETE["${col}"]}"
  done
}

function dispatch::carousel {
  yaml::ensure map .carousel "${1}"
  local -n ctx="${1}"
  local -n carr="${ctx[carousel]}"

  read -r carr_enabled < <(to-boolean "${carr[enabled]}")
  fill-template "carousel_enabled" "${carr_enabled}"

  read -r carr_interval < <(to-natural "${carr[interval]}" 30000)
  fill-template "carousel_interval" "${carr_interval}"
}

function dispatch::background {
  yaml::ensure list .background.sources "${1}"
  local -n ctx="${1}"
  local -n images_n="${2}"
  local -n videos_n="${3}"
  local -n use_video_n="${4}"
  local -n background="${ctx[background]}"
  local -n sources="${background[sources]}"

  read -r use_video_n < <(to-boolean "${background[use_video]}")
  fill-template "use_video" "${use_video_n}"

  log "Sorting through target background file paths..."
  for bg in "${sources[@]}"; do
    [[ -f "${bg}" ]] || die "File ${bg} does not exist, or is inaccessible"
    if is-video "${bg}"; then
      videos_n+=("${bg}")
    elif is-image "${bg}"; then
      images_n+=("${bg}")
    else
      die "File ${bg} is not a valid background"
    fi
  done

  local _bgs=()
  for bg in "${images_n[@]##*/}"; do
    log "Adding background image: ${bg}"
    _bgs+=("    \"${WINU_THEME_ROOT}/assets/${bg}\",")
  done
  for bg in "${videos_n[@]##*/}"; do
    log "Adding background video: ${bg}"
    _bgs+=("    \"${WINU_THEME_ROOT}/assets/${bg}\",")
  done

  IFS=$'\n' __bgs="${_bgs[*]}"
  IFS=$' \t\n'
  WINU_CONFIG_TEMPLATE="${WINU_CONFIG_TEMPLATE/\{bg_list\}/"${__bgs}"}"

  read -r intensity < <(to-natural "${background[blur]}" 0)
  ((intensity > 100)) && die "Background intensity blur cannot be greater than 100"
  local blur_enabled=true
  ((intensity == 0)) && blur_enabled=false

  local radius=$(((intensity * 32) / 100))
  local samples=$(((radius * 2) + 1))

  # required to directly disable blur element
  fill-template "use_blur" "${blur_enabled}"
  fill-template "blur_radius" "${radius}"
  fill-template "blur_samples" "${samples}"

  dispatch::carousel "${ctx[background]}"
}

function dispatch::fonts {
  yaml::ensure map .fonts "${1}"
  local -n ctx="${1}"
  local -n fonts="${ctx[fonts]}"

  log "Validating setup configuration typography families..."
  for font in "${!fonts[@]}"; do
    local font_fam="${fonts["${font}"]}"
    is-valid-font "${font_fam}" || die "Font family '${font_fam}' not found globally"
    fill-template "font:${font}" "${font_fam}" "Adding font"
  done
}

function winu::sync_config {
  [[ -d "${WINU_THEME_ROOT:?}" ]] || die "Missing theme root: run setup first!"
  read -r inactive_timeout < <(to-natural "${__ynml[inactive_timeout]}" 10000)
  fill-template "inactive_timeout" "${inactive_timeout}"

  local image_bgs=()
  local video_bgs=()
  local use_video
  dispatch::background __ynml image_bgs video_bgs use_video
  dispatch::colors __ynml "${use_video}" "${image_bgs[0]}" "${video_bgs[0]}"
  dispatch::fonts __ynml
  dispatch::compositor __ynml
  dispatch::avatar __ynml

  log "Writing theme configuration..."
  cat <<< "${WINU_CONFIG_TEMPLATE}" > "${WINU_THEME_ROOT}/Config.qml.tmp" || die "huh!? wdym failed cat? :cat: (write conf err)"
  mv "${WINU_THEME_ROOT}/Config.qml.tmp" "${WINU_THEME_ROOT}/Config.qml"

  if [[ -f "${WINU_TMP_COMP_EXEC}" ]]; then
    mv "${WINU_TMP_COMP_EXEC}" "${WINU_SDDM_COMP_EXEC}"
    chmod 755 "${WINU_SDDM_COMP_EXEC}"
  fi

  log "Purging existing assets directory..."
  rm -fr "${WINU_THEME_ROOT}/assets"
  mkdir -p "${WINU_THEME_ROOT}/assets"

  mv "${WINU_TMP_IMAGE}" "${WINU_THEME_ROOT}/assets/user-pic.png"
  cp "${image_bgs[@]}" "${video_bgs[@]}" "${WINU_THEME_ROOT}/assets/" || die "huh!? how's this pc so bipolar? :sob: (cp failed)"

  log "SDDM Theme configuration synchronization operations completed."
}

function winu::setup {
  [[ -z "${installation[source]}" ]] && die "Missing source path (path to git cloned repo)"
  local source_path="${installation[source]}"
  [[ -d "${source_path}" ]] || die "Source path does not exist"
  local pkg_to_install=(
    qt5-base qt5-declarative qt5-quickcontrols2
    qt5-graphicaleffects qt5-multimedia qt5-wayland
    inotify-tools procps-ng util-linux dbus sddm
  )
  read -r optional_pkg_too < <(to-boolean "${installation[optional_deps]}")
  ${optional_pkg_too} && pkg_to_install+=(ffmpeg imagemagick matugen)

  log "Installing selected dependencies..."
  pacman -Sy --noconfirm --needed "${pkg_to_install[@]}" || {
    log "sudo pacman -Syy --noconfirm --needed ${pkg_to_install[*]}"
    die "Installation failed, try running the command manually"
  }

  rm -fr "${WINU_THEME_ROOT:?}"
  mkdir -p "${WINU_THEME_ROOT}"
  local files_to_copy=(
    "${source_path}/src"
    "${source_path}/Main.qml"
    "${source_path}/sddm-compositor"
    "${source_path}/matugen.toml"
  )

  cp -r "${files_to_copy[@]}" "${WINU_THEME_ROOT}" || {
    log "Make sure source folder actually is the correct one"
    die "Copy failed, removing folder created"
  }

  log "Successfully installed: run sync to create configs! Then run test for safety"
}

function winu::test {
  [[ -d "${WINU_THEME_ROOT:?}" ]] || die 'Missing theme root: run setup first!'
  [[ -f "${WINU_THEME_ROOT}/Config.qml" ]] || die 'Missing theme config: run sync first!'
  is-command sddm-greeter || die 'sddm not available: run setup first!'
  sddm-greeter --test-mode --theme "${WINU_THEME_ROOT}"
}

function winu::help {
  local b=""
  local c=""
  local v=""
  local r=""

  if [[ -t 1 ]]; then
    b="\x1b[1;34m"
    c="\x1b[38;5;14m"
    v="\x1b[38;5;15m"
    r="\x1b[0m"
  fi

  local help_lines=(
    "${b}winu${r}: Windows 11 inspired SDDM theme with Material You colors"
    ''
    "${b}Usage${r}:"
    "  ${c}winu${r} COMMAND [config.yaml]"
    ''
    "${b}Commands${r}:"
    "  ${c}setup${r}   Install dependencies and prepare theme environment"
    "  ${c}sync${r}    Synchronize theme assets and configuration files"
    "  ${c}test${r}    Launch SDDM greeter in test mode"
    "  ${c}help${r}    Show this help message"
    ''
    "${b}Notes${r}:"
    "  - ${c}setup${r} and ${c}sync${r} require root privileges."
    "  - ${c}test${r} must be run as your standard user."
    '  - If [config.yaml] is omitted, the default path is ~/.config/winu.yaml'
    '    and is only available when the original user can be determined (e.g. via sudo)'
    ''
    "${b}Examples${r}:"
    "  sudo ${c}winu${r} setup"
    "  sudo ${c}winu${r} sync /etc/winu.yaml"
    "  ${c}winu${r} test"
  )

  printf '%b\n' "${help_lines[@]}"
  exec true
}

function main {
  ((${#} < 1)) && die "Usage: ${0} <command> [config.yaml]"

  local conf_path_mb=''
  case "${1}" in
    sync | setup)
      ((UID != 0)) && die 'Required to run as root for sync or setup'
      conf_path_mb="${SUDO_USER:+/home/${SUDO_USER}/.config/winu.yaml}"
      ;;
    test)
      ((UID == 0)) && die 'Command "test" must be run as a regular user, not root!'
      conf_path_mb="${HOME:?:wilted_flower::wilted_flower::wilted_flower:}/.config/winu.yaml"
      ;;
    help) winu::help ;;
    *)
      die "Unknown command: ${1}"
      ;;
  esac

  declare -gr WINU_CONFIG_FILE="${2:-${conf_path_mb}}"
  [[ -n "${WINU_CONFIG_FILE}" ]] || die "Config file not provided"
  [[ -f "${WINU_CONFIG_FILE}" ]] || die "Config file '${WINU_CONFIG_FILE}' not found"

  log "Configuration from path: ${WINU_CONFIG_FILE}"
  yaml::load __ynml "${WINU_CONFIG_FILE}"

  yaml::ensure map .installation __ynml
  local -n installation="${__ynml[installation]}"
  readonly WINU_THEME_ROOT="${installation[root]:-${WINU_THEME_ROOT}}"
  readonly WINU_MATUGEN_CONFIG="${WINU_THEME_ROOT}/matugen.toml"

  case "${1}" in
    sync) winu::sync_config __ynml ;;
    setup) winu::setup __ynml ;;
    test) winu::test __ynml ;;
  esac
}

trap 'become-suicidal-ahh' ERR
set -E
main "${@}"
